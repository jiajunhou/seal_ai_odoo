<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vector Index Views -->
    <record id="view_ai_vector_index_list" model="ir.ui.view">
        <field name="name">ai.vector.index.list</field>
        <field name="model">ai.vector.index</field>
        <field name="arch" type="xml">
            <list decoration-success="active == True" decoration-muted="active == False">
                <field name="name"/>
                <field name="index_type"/>
                <field name="distance_metric"/>
                <field name="dimensions"/>
                <field name="model_name"/>
                <field name="document_count"/>
                <field name="embedding_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ai_vector_index_form" model="ir.ui.view">
        <field name="name">ai.vector.index.form</field>
        <field name="model">ai.vector.index</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="索引名称"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="index_type"/>
                            <field name="distance_metric"/>
                        </group>
                        <group>
                            <field name="dimensions"/>
                            <field name="model_name"/>
                            <field name="description"/>
                        </group>
                    </group>
                    <group string="统计">
                        <group>
                            <field name="document_count"/>
                            <field name="embedding_count"/>
                            <field name="total_chunks"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_vector_index" model="ir.actions.act_window">
        <field name="name">向量索引</field>
        <field name="res_model">ai.vector.index</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
