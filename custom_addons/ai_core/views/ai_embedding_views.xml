<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_embedding_list" model="ir.ui.view">
        <field name="name">ai.embedding.list</field>
        <field name="model">ai.embedding</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="model_name"/>
                <field name="vector_dimensions"/>
                <field name="document_id"/>
                <field name="chunk_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ai_embedding_form" model="ir.ui.view">
        <field name="name">ai.embedding.form</field>
        <field name="model">ai.embedding</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="document_id"/>
                        <field name="chunk_id"/>
                        <field name="vector_index_id"/>
                        <field name="model_name"/>
                        <field name="vector_dimensions"/>
                    </group>
                    <group string="Vector Preview">
                        <field name="vector_json" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_embedding" model="ir.actions.act_window">
        <field name="name">Embeddings</field>
        <field name="res_model">ai.embedding</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
