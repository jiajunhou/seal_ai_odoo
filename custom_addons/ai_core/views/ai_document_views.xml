<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_ai_document_tree" model="ir.ui.view">
        <field name="name">ai.document.tree</field>
        <field name="model">ai.document</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'error'" decoration-success="state == 'ready'" decoration-info="state == 'uploaded'">
                <field name="name" string="文档名称"/>
                                <field name="document_type" decoration-info="document_type != False"/>
                <field name="state" decoration-info="state in ('draft','uploaded')" decoration-success="state == 'ready'" decoration-warning="state in ('parsing','chunking','embedding')" decoration-danger="state == 'error'"/>
                <field name="datas_fname" string="文件名" optional="show"/>
                <field name="file_size" string="大小" optional="hide"/>
                <field name="page_count" string="页数" optional="hide"/>
                <field name="word_count" string="字数" optional="hide"/>
                <field name="chunk_count" string="分块数" optional="show"/>
                <field name="embedding_count" string="嵌入数" optional="show"/>
                <field name="user_id" string="上传者" optional="hide"/>
                <field name="create_date" string="创建时间" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_ai_document_form" model="ir.ui.view">
        <field name="name">ai.document.form</field>
        <field name="model">ai.document</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,uploaded,parsing,chunking,embedding,ready"/>
                    <button name="action_process" string="处理" type="object"
                            invisible="state != 'uploaded'" class="btn-primary"
                            confirm="处理此文档？将进行解析、分块和生成嵌入向量。"/>
                    <button name="action_reprocess" string="重新处理" type="object"
                            invisible="state not in ('ready','error')" class="btn-warning"/>
                    <button name="action_reset" string="重置" type="object"
                            invisible="state == 'draft'" class="btn-secondary"/>
                </header>
                <sheet>
                                        <div class="oe_button_box" name="button_box">
                        <button name="action_view_chunks" string="分块数" type="object"
                                class="o_stat_button" icon="fa-file-text-o">
                            <div class="o_stat_info">
                                <field name="chunk_count"/>
                            </div>
                        </button>
                        <button name="action_view_embeddings" string="嵌入数" type="object"
                                class="o_stat_button" icon="fa-database">
                            <div class="o_stat_info">
                                <field name="embedding_count"/>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="文档名称"/>
                        </h1>
                        <group>
                            <group>
                                                                <field name="document_type"/>
                                <field name="state"/>
                                <field name="datas_fname" string="文件名"/>
                            </group>
                            <group>
                                <field name="user_id"/>
                                <field name="create_date"/>
                            </group>
                        </group>
                    </div>

                    <notebook>
                        <page name="file" string="文件">
                            <group name="file_info">
                                <field name="datas" filename="datas_fname" string="文件" widget="binary"/>
                                <field name="file_size" string="大小"/>
                                <field name="mime_type"/>
                                <field name="file_extension"/>
                            </group>
                        </page>

                        <page name="processing" string="处理">
                            <group name="config" string="配置">
                                <group>
                                    <field name="chunk_strategy"/>
                                    <field name="chunk_size"/>
                                    <field name="chunk_overlap"/>
                                </group>
                                <group>
                                    <field name="embedding_model"/>
                                    <field name="embedding_dimensions"/>
                                    <field name="vector_index_id"/>
                                </group>
                            </group>
                                                        <group name="stats" string="统计" invisible="state not in ('ready','error')">
                                <group>
                                    <field name="page_count"/>
                                    <field name="word_count"/>
                                    <field name="character_count"/>
                                </group>
                                <group>
                                    <field name="chunk_count"/>
                                    <field name="embedding_count"/>
                                    <field name="process_duration"/>
                                    <field name="processed_date"/>
                                </group>
                            </group>
                            <group name="error" string="错误" invisible="state != 'error'">
                                <field name="error_message" nolabel="1"/>
                            </group>
                        </page>

                        <page name="content" string="内容">
                            <field name="raw_text" nolabel="1" readonly="True"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_ai_document_search" model="ir.ui.view">
        <field name="name">ai.document.search</field>
        <field name="model">ai.document</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="文档名称"/>
                <field name="datas_fname" string="文件名"/>
                <field name="raw_text" string="内容"/>
                <filter name="state_ready" string="Ready" domain="[('state','=','ready')]"/>
                <filter name="state_error" string="错误" domain="[('state','=','error')]"/>
                <filter name="state_uploaded" string="Uploaded" domain="[('state','=','uploaded')]"/>
                <filter name="state_draft" string="Draft" domain="[('state','=','draft')]"/>
                <separator/>
                <filter name="type_pdf" string="PDF" domain="[('document_type','=','pdf')]"/>
                <filter name="type_docx" string="DOCX" domain="[('document_type','=','docx')]"/>
                <filter name="type_txt" string="TXT" domain="[('document_type','=','txt')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_type" string="文档类型" context="{'group_by': 'document_type'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_user" string="上传者" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ai_document" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">ai.document</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                上传您的第一个文档进行AI处理。
            </p>
            <p>
                Upload PDF, DOCX, or TXT files to build a searchable knowledge base.
                Documents are automatically parsed, chunked, and embedded for AI retrieval.
            </p>
        </field>
    </record>
</odoo>
