<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- AI Configuration Settings -->
    <record id="view_ai_config_settings" model="ir.ui.view">
        <field name="name">AI Configuration Settings</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form class="o_configuration_wizard" string="AI设置">
                <header>
                    <button string="保存" type="object" name="execute" class="btn-primary"/>
                    <button string="取消" special="cancel" type="object"/>
                </header>
                <div class="o_setting_container">
                    <div class="settings">
                        <div class="app-name">
                            <h2>AI核心配置</h2>
                        </div>

                        <!-- Chat Backend -->
                        <div class="o_setting_box" id="ai_chat_backend">
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">AI聊天后端</span>
                                <div class="text-muted">
                                    选择AI聊天的后端（DeepSeek / OpenAI / 通义千问）
                                </div>
                                <div class="content-group mt16">
                                    <div class="row">
                                        <span class="o_form_label col-lg-3">后端</span>
                                        <div class="col-lg-9">
                                            <field name="ai_chat_backend" class="o_input"/>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <span class="o_form_label col-lg-3">API密钥</span>
                                        <div class="col-lg-9">
                                            <field name="ai_openai_api_key" password="True" placeholder="sk-..."/>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <span class="o_form_label col-lg-3">聊天模型</span>
                                        <div class="col-lg-9">
                                            <field name="ai_chat_model" placeholder="deepseek-chat"/>
                                            <div class="text-muted small">
                                                OpenAI: gpt-4o-mini | DeepSeek: deepseek-chat | Qwen: qwen-plus
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <span class="o_form_label col-lg-3">自定义端点</span>
                                        <div class="col-lg-9">
                                            <field name="ai_custom_endpoint" placeholder="http://localhost:11434/v1/chat/completions"/>
                                            <div class="text-muted small">
                                                预设后端自动填入，自定义兼容模式可手动修改
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Embedding Config -->
                        <div class="o_setting_box" id="ai_embedding_config">
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">嵌入配置</span>
                                <div class="text-muted">
                                    配置文本块如何转换为向量。
                                </div>
                                <div class="content-group mt16">
                                    <div class="row">
                                        <span class="o_form_label col-lg-3">后端</span>
                                        <div class="col-lg-9">
                                            <field name="ai_embedding_backend" class="o_input"/>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <span class="o_form_label col-lg-3">模型</span>
                                        <div class="col-lg-9">
                                            <field name="ai_embedding_model"/>
                                            <div class="text-muted small">
                                                OpenAI: text-embedding-ada-002 | Qwen: text-embedding-v2
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <span class="o_form_label col-lg-3">维度</span>
                                        <div class="col-lg-9">
                                            <field name="ai_embedding_dimensions"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Chunking Defaults -->
                        <div class="o_setting_box" id="ai_chunking_defaults">
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">默认分块配置</span>
                                <div class="text-muted">
                                    文档分块的默认设置。
                                </div>
                                <div class="content-group mt16">
                                    <div class="row">
                                        <span class="o_form_label col-lg-3">策略</span>
                                        <div class="col-lg-9">
                                            <field name="ai_default_chunk_strategy" class="o_input"/>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <span class="o_form_label col-lg-3">分块大小</span>
                                        <div class="col-lg-9">
                                            <field name="ai_default_chunk_size"/>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <span class="o_form_label col-lg-3">分块重叠</span>
                                        <div class="col-lg-9">
                                            <field name="ai_default_chunk_overlap"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </field>
    </record>

            <!-- Action for Settings -->
    <record id="action_ai_config_settings" model="ir.actions.act_window">
        <field name="name">AI设置</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_ai_config_settings"/>
        <field name="target">inline</field>
    </record>

</odoo>
