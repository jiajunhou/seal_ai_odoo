<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- AI Configuration Settings -->
    <record id="view_ai_config_settings" model="ir.ui.view">
        <field name="name">AI Configuration Settings</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form class="o_configuration_wizard" string="AI Settings">
                <div class="o_setting_container">
                    <div class="settings">
                        <div class="app-name">
                            <h2>AI Core Configuration</h2>
                        </div>

                        <!-- Chat Backend -->
                        <div class="o_setting_box" id="ai_chat_backend">
                            <div class="o_setting_right_pane">
                                <label for="ai_chat_backend_select" string="AI Chat Backend"/>
                                <div class="text-muted">
                                    Choose the backend for AI chat completions.
                                </div>
                                <div class="content-group mt16">
                                    <select class="o_input o_setting_select" id="ai_chat_backend_select">
                                        <option value="mock">Mock (Development)</option>
                                        <option value="openai">OpenAI API</option>
                                        <option value="openai_compatible">Custom OpenAI-compatible</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- OpenAI Configuration -->
                        <div class="o_setting_box" id="ai_openai_config">
                            <div class="o_setting_right_pane">
                                <label string="OpenAI API Configuration"/>
                                <div class="text-muted">
                                    Configure OpenAI API access for chat and embeddings.
                                </div>
                                <div class="content-group mt16">
                                    <div class="row">
                                        <label string="API Key" class="col-lg-3 o_label"/>
                                        <div class="col-lg-9">
                                            <input type="password" class="o_input" id="ai_openai_api_key"
                                                   placeholder="sk-..."/>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <label string="Chat Model" class="col-lg-3 o_label"/>
                                        <div class="col-lg-9">
                                            <input type="text" class="o_input" id="ai_chat_model"
                                                   value="gpt-4o-mini"/>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <label string="Custom Endpoint" class="col-lg-3 o_label"/>
                                        <div class="col-lg-9">
                                            <input type="text" class="o_input" id="ai_custom_endpoint"
                                                   placeholder="http://localhost:11434/v1/chat/completions"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Embedding Configuration -->
                        <div class="o_setting_box" id="ai_embedding_config">
                            <div class="o_setting_right_pane">
                                <label string="Embedding Configuration"/>
                                <div class="text-muted">
                                    Configure how text chunks are converted to vectors.
                                </div>
                                <div class="content-group mt16">
                                    <div class="row">
                                        <label string="Backend" class="col-lg-3 o_label"/>
                                        <div class="col-lg-9">
                                            <select class="o_input" id="ai_embedding_backend">
                                                <option value="mock">Mock (Development)</option>
                                                <option value="openai">OpenAI API</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <label string="Model" class="col-lg-3 o_label"/>
                                        <div class="col-lg-9">
                                            <input type="text" class="o_input" id="ai_embedding_model"
                                                   value="text-embedding-ada-002"/>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <label string="Dimensions" class="col-lg-3 o_label"/>
                                        <div class="col-lg-9">
                                            <input type="number" class="o_input" id="ai_embedding_dimensions"
                                                   value="1536"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Default Chunking -->
                        <div class="o_setting_box" id="ai_chunking_defaults">
                            <div class="o_setting_right_pane">
                                <label string="Default Chunking Configuration"/>
                                <div class="text-muted">
                                    Default settings for document chunking.
                                </div>
                                <div class="content-group mt16">
                                    <div class="row">
                                        <label string="Strategy" class="col-lg-3 o_label"/>
                                        <div class="col-lg-9">
                                            <select class="o_input" id="ai_default_chunk_strategy">
                                                <option value="recursive">Recursive Split</option>
                                                <option value="token">Token-based</option>
                                                <option value="semantic">Semantic</option>
                                                <option value="fixed">Fixed Size</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <label string="Chunk Size" class="col-lg-3 o_label"/>
                                        <div class="col-lg-9">
                                            <input type="number" class="o_input" id="ai_default_chunk_size"
                                                   value="512"/>
                                        </div>
                                    </div>
                                    <div class="row mt8">
                                        <label string="Chunk Overlap" class="col-lg-3 o_label"/>
                                        <div class="col-lg-9">
                                            <input type="number" class="o_input" id="ai_default_chunk_overlap"
                                                   value="50"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </field>
    </record>

    <!-- Action for Settings -->
    <record id="action_ai_config_settings" model="ir.actions.act_window">
        <field name="name">AI Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_ai_config_settings"/>
        <field name="target">inline</field>
    </record>
</odoo>
