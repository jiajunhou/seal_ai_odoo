<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Conversation Tree View -->
    <record id="view_ai_conversation_tree" model="ir.ui.view">
        <field name="name">ai.conversation.tree</field>
        <field name="model">ai.conversation</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'active'" decoration-muted="state == 'archived'">
                <field name="name" string="主题"/>
                <field name="state" decoration-success="state == 'active'" decoration-muted="state == 'archived'"/>
                <field name="model_name" string="Model"/>
                <field name="message_count" string="消息数"/>
                <field name="total_tokens_used" string="Token数"/>
                <field name="last_message_date" string="最后消息"/>
                <field name="user_id" string="用户" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Conversation Form View -->
    <record id="view_ai_conversation_form" model="ir.ui.view">
        <field name="name">ai.conversation.form</field>
        <field name="model">ai.conversation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_archive" string="归档" type="object" invisible="state != 'active'"/>
                    <button name="action_unarchive" string="取消归档" type="object" invisible="state != 'archived'"/>
                    <button name="action_close" string="关闭" type="object" invisible="state not in ('active','archived')"/>
                    <button name="action_clear_messages" string="清空消息" type="object"
                            confirm="Delete all messages in this conversation?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="对话主题"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="state" decoration-success="state == 'active'" decoration-muted="state == 'archived'"/>
                            <field name="user_id"/>
                            <field name="model_name"/>
                        </group>
                        <group>
                            <field name="temperature" widget="float"/>
                            <field name="max_tokens"/>
                            <field name="message_count" string="总消息数"/>
                            <field name="total_tokens_used" string="已用Token数"/>
                        </group>
                    </group>

                    <notebook>
                        <page name="context" string="上下文设置">
                            <group name="rag_settings" string="RAG设置">
                                <field name="use_rag"/>
                                <field name="use_crm_context"/>
                                <field name="top_k_chunks"/>
                                <field name="similarity_threshold"/>
                            </group>
                            <group name="crm_context" string="CRM上下文">
                                <field name="partner_ids" widget="many2many_tags"/>
                                <field name="sale_order_ids" widget="many2many_tags"/>
                            </group>
                            <group name="knowledge" string="知识库">
                                <field name="document_ids" widget="many2many_tags"/>
                            </group>
                        </page>

                        <page name="system" string="系统提示词">
                            <field name="system_prompt" nolabel="1"/>
                        </page>

                                                <page name="messages" string="消息数">
                            <field name="chat_message_ids" nolabel="1">
                                <list>
                                                                        <field name="role" decoration-primary="role == 'user'"
                                           decoration-success="role == 'assistant'" decoration-info="role == 'system'"/>
                                    <field name="content" string="消息"/>
                                    <field name="model_name" string="Model"/>
                                    <field name="tokens_used" string="Token数"/>
                                    <field name="response_time_ms" string="时间(毫秒)"/>
                                                                        <field name="rag_context_used" class="o_boolean_toggle"/>
                                    <field name="crm_context_used" class="o_boolean_toggle"/>
                                    <field name="create_date" string="时间"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Conversation Search View -->
    <record id="view_ai_conversation_search" model="ir.ui.view">
        <field name="name">ai.conversation.search</field>
        <field name="model">ai.conversation</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="model_name"/>
                <field name="partner_ids"/>
                <field name="sale_order_ids"/>
                <filter name="state_active" string="Active" domain="[('state','=','active')]"/>
                <filter name="state_archived" string="Archived" domain="[('state','=','archived')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_model" string="Model" context="{'group_by': 'model_name'}"/>
                    <filter name="group_user" string="用户" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ai_conversation" model="ir.actions.act_window">
        <field name="name">AI聊天对话</field>
        <field name="res_model">ai.conversation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                开始一个新的AI驱动对话。
            </p>
            <p>
                Use AI chat to ask questions about your CRM data and knowledge base documents.
                Conversations can include context from customers, sales orders, and uploaded documents.
            </p>
        </field>
    </record>
</odoo>
